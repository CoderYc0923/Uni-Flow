{
  "name": "virtual-uni-flow",
  "version": "0.1.0",
  "description": "Production-grade unified agent workflow orchestration (TypeScript Engine, YAML, Workflow-as-Unit)",
  "license": "MIT",
  "author": "CoderYc0923",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/uniflow.workflow.schema.json": "./schemas/uniflow.workflow.schema.json"
  },
  "bin": {
    "uniflow": "dist/cli/uniflow.js"
  },
  "files": [
    "dist",
    "schemas",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "uniflow": "node ./dist/cli/uniflow.js",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs-web",
    "docs:api": "typedoc",
    "docs:build": "npm run docs:api && vitepress build docs-web"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CoderYc0923/Uni-Flow.git"
  },
  "homepage": "https://CoderYc0923.github.io/Uni-Flow/",
  "bugs": {
    "url": "https://github.com/CoderYc0923/Uni-Flow/issues"
  },
  "keywords": [
    "agent",
    "workflow",
    "orchestration",
    "multi-agent",
    "yaml",
    "typescript",
    "uniflow"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.1",
    "ajv": "^8.20.0",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "mermaid": "^11.16.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
